# FastAPI Settings
PORT=8000
DEBUG=true

# Security (AES-256 Key for encrypting sensitive fields)
# Generate a 32-byte hex key: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_SECRET_KEY=your_encryption_secret_key_hex_here

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/resumeiq

# Clerk Authentication
CLERK_API_URL=https://api.clerk.com/v1
CLERK_SECRET_KEY=sk_test_...

# Supabase Storage
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...
SUPABASE_BUCKET_NAME=resumes

# Midtrans Payment
MIDTRANS_SERVER_KEY=SB-Mid-server-...
MIDTRANS_CLIENT_KEY=SB-Mid-client-...
MIDTRANS_IS_PRODUCTION=false

# Google Gemini API
GEMINI_API_KEY=AIzaSy...

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-apiv1-...
